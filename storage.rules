rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /drug-pdfs/{allPaths=**} {
      // Allow read access to everyone (for doctors to view)
      allow read: if true;
      // Allow write access only to authenticated users (pharmacists/admins)
      allow write: if request.auth != null && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
