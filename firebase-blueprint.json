      "properties": {
        "MA_LK": { "type": "string" },
        "TEN_THUOC": { "type": "string" },
        "SO_LUONG": { "type": "string" },
        "DON_GIA": { "type": "string" }
      },
      "required": ["MA_LK", "TEN_THUOC"]
    },
    "PatientSupply": {
      "title": "PatientSupply",
      "description": "Thông tin vật tư y tế sử dụng của bệnh nhân.",
      "type": "object",
      "properties": {
        "MA_LK": { "type": "string" },
        "TEN_VAT_TU": { "type": "string" },
        "SO_LUONG": { "type": "string" }
      },
      "required": ["MA_LK"]
    },
    "PatientSubclinical": {
      "title": "PatientSubclinical",
      "description": "Thông tin cận lâm sàng của bệnh nhân.",
      "type": "object",
      "properties": {
        "MA_LK": { "type": "string" },
        "TEN_CHI_SO": { "type": "string" },
        "GIA_TRI": { "type": "string" }
      },
      "required": ["MA_LK"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Thông tin nhân sự bệnh viện (Bác sĩ, Dược sĩ, Điều dưỡng).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "type": { "type": "string", "enum": ["Bác sĩ", "Dược sĩ", "Điều dưỡng"] },
        "gender": { "type": "string", "enum": ["Nam", "Nữ"] },
        "dob": { "type": "string" },
        "address": { "type": "string" },
        "specialty": { "type": "string" },
        "position": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "certificateCode": { "type": "string" },
        "department": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "type", "gender", "dob"]
    },
    "CalendarEvent": {
      "title": "CalendarEvent",
      "description": "Sự kiện trong lịch công tác.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["meeting", "duty", "surgery", "other"] },
        "location": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "startDate", "endDate", "type", "createdBy"]
    },
    "Note": {
      "title": "Note",
      "description": "Ghi chú cá nhân.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "color": { "type": "string" },
        "isPinned": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "createdBy", "createdAt", "updatedAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Thông báo hệ thống cho người dùng.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "UID của người nhận thông báo" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "link": { "type": "string", "description": "Tab ID để chuyển hướng khi nhấn" }
      },
      "required": ["id", "userId", "title", "message", "type", "isRead", "createdAt"]
    },
