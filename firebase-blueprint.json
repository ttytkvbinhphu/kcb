{
  "entities": {
    "Drug": {
      "title": "Drug",
      "description": "Thông tin chi tiết về thuốc trong danh mục.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID duy nhất của thuốc" },
        "name": { "type": "string", "description": "Tên thuốc" },
        "activeIngredients": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "amount": { "type": "string" },
              "unit": { "type": "string" }
            }
          },
          "description": "Danh sách các hoạt chất, hàm lượng và đơn vị" 
        },
        "atcCode": { "type": "string", "description": "Mã ATC" },
        "dosageForm": { "type": "string", "description": "Dạng bào chế" },
        "excipients": { "type": "string", "description": "Tá dược" },
        "manufacturer": { "type": "string", "description": "Nhà sản xuất" },
        "indications": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "content": { "type": "string" },
              "icd10": { "type": "string" },
              "icd10s": { "type": "array", "items": { "type": "string" } }
            }
          }, 
          "description": "Chỉ định kèm mã ICD-10 gợi ý" 
        },
        "contraindications": { 
          "type": "array", 
          "items": { 
             "type": "object",
             "properties": {
               "type": { "type": "string" },
               "content": { "type": "string" }
             }
          }, 
          "description": "Chống chỉ định" 
        },
        "sideEffects": { "type": "array", "items": { "type": "any" }, "description": "Tác dụng phụ" },
        "groupId": { "type": "string", "description": "ID nhóm thuốc chính" },
        "groupIds": { "type": "array", "items": { "type": "string" }, "description": "Danh sách ID các nhóm thuốc" },
        "avatarUrl": { "type": "string", "description": "URL ảnh đại diện thuốc" },
        "isRx": { "type": "boolean", "description": "Thuốc kê đơn" },
        "isClosed": { "type": "boolean", "description": "Trạng thái đóng/mở thuốc (ẩn với người dùng thông thường)" },
        "pdfUrl": { "type": "string", "description": "URL file HDSD" },
        "registrationNumber": { "type": "string" },
        "leafletVersion": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "generalAdministration": { "type": "string" },
        "dosageAndAdministration": { "type": "array", "items": { "type": "object" } },
        "pharmacodynamics": { "type": "array", "items": { "type": "object" } },
        "pharmacokinetics": { "type": "array", "items": { "type": "object" } },
        "specificInteractions": { "type": "array", "items": { "type": "object" } },
        "precautions": { "type": "string" },
        "pregnancy": { "type": "string" },
        "lactation": { "type": "string" },
        "interactions": { "type": "string" },
        "driving": { "type": "string", "description": "Ảnh hưởng đến lái xe, vận hành máy móc" },
        "overdose": { "type": "string" }
      },
      "required": ["id", "name", "activeIngredients"]
    },
    "Prescription": {
      "title": "Prescription",
      "description": "Thông tin đơn thuốc đã kê cho bệnh nhân.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID duy nhất của đơn thuốc" },
        "patientName": { "type": "string", "description": "Tên bệnh nhân" },
        "patientAge": { "type": "number", "description": "Tuổi bệnh nhân" },
        "patientGender": { "type": "string", "enum": ["Nam", "Nữ"], "description": "Giới tính" },
        "diagnosis": { "type": "string", "description": "Chẩn đoán lâm sàng" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "drugId": { "type": "string" },
              "drugName": { "type": "string" },
              "dosage": { "type": "string" },
              "frequency": { "type": "string" },
              "duration": { "type": "string" },
              "note": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Thời gian tạo đơn" },
        "doctorName": { "type": "string", "description": "Tên bác sĩ kê toa" },
        "doctorUid": { "type": "string", "description": "UID của bác sĩ" }
      },
      "required": ["id", "patientName", "diagnosis", "items", "createdAt", "doctorUid"]
    },
    "User": {
      "title": "User",
      "description": "Thông tin người dùng hệ thống (Bác sĩ/Dược sĩ).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "UID từ Firebase Auth" },
        "email": { "type": "string", "format": "email", "description": "Email người dùng" },
        "displayName": { "type": "string", "description": "Tên hiển thị" },
        "title": { "type": "string", "description": "Chức danh (Bác sĩ, Dược sĩ...)" },
        "position": { "type": "string", "description": "Chức vụ (Giám đốc, Nhân viên...)" },
        "specialty": { "type": "string", "description": "Chuyên môn (Tiến sĩ, Thạc sĩ...)" },
        "department": { "type": "string", "description": "Khoa/Phòng" },
        "role": { "type": "string", "enum": ["admin", "operator", "member", "operator_doctor", "operator_pharmacist"], "description": "Vai trò trong hệ thống" },
        "isApproved": { "type": "boolean", "description": "Trạng thái phê duyệt tài khoản" },
        "photoURL": { "type": "string" },
        "photoSyncToken": { "type": "string" },
        "hideEmail": { "type": "boolean" },
        "hiddenQuickActions": { "type": "array", "items": { "type": "string" } },
        "zalo": { "type": "string" },
        "hideZalo": { "type": "boolean" },
        "hasSeenWelcome": { "type": "boolean" },
        "isHidden": { "type": "boolean" },
        "pinnedIcdCodes": { "type": "array", "items": { "type": "string" } },
        "workspaceIcdCodes": { "type": "array", "items": { "type": "string" } },
        "lastActive": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "ICD10": {
      "title": "ICD10",
      "description": "Danh mục mã bệnh ICD-10.",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "Mã bệnh" },
        "description": { "type": "string", "description": "Mô tả bệnh" },
        "commonDrugs": { "type": "array", "items": { "type": "string" }, "description": "Gợi ý thuốc thường dùng" },
        "isAppendixA2": { "type": "boolean", "description": "Nằm trong phụ lục A2" },
        "isRestricted": { "type": "boolean", "description": "Mã hạn chế sử dụng" },
        "notes": { "type": "string", "description": "Ghi chú thêm" },
        "chapter": { "type": "string", "description": "Chương bệnh" }
      },
      "required": ["code", "description"]
    },
    "ADRReport": {
      "title": "ADRReport",
      "description": "Báo cáo phản ứng có hại của thuốc (ADR).",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID báo cáo" },
        "patientInitials": { "type": "string", "description": "Tên viết tắt bệnh nhân" },
        "patientAge": { "type": "number", "description": "Tuổi bệnh nhân" },
        "patientGender": { "type": "string", "enum": ["Nam", "Nữ", "Khác"], "description": "Giới tính" },
        "drugId": { "type": "string", "description": "ID thuốc nghi ngờ" },
        "drugName": { "type": "string", "description": "Tên thuốc nghi ngờ" },
        "reactionDescription": { "type": "string", "description": "Mô tả phản ứng" },
        "severity": { "type": "string", "enum": ["Nhẹ", "Trung bình", "Nặng", "Nghiêm trọng"], "description": "Mức độ nghiêm trọng" },
        "outcome": { "type": "string", "enum": ["Hồi phục", "Đang hồi phục", "Có di chứng", "Tử vong", "Không rõ"], "description": "Kết quả" },
        "reporterName": { "type": "string", "description": "Tên người báo cáo" },
        "reporterUid": { "type": "string", "description": "UID người báo cáo" },
        "reportedAt": { "type": "string", "format": "date-time", "description": "Thời gian báo cáo" },
        "status": { "type": "string", "enum": ["Mới", "Đang xử lý", "Đã hoàn thành"], "description": "Trạng thái xử lý" },
        "notes": { "type": "string", "description": "Ghi chú thêm" }
      },
      "required": ["id", "patientInitials", "drugId", "reactionDescription", "severity", "reporterUid", "reportedAt", "status"]
    },
    "ADRCatalogItem": {
      "title": "ADRCatalogItem",
      "description": "Danh mục các phản ứng có hại (ADR) thường gặp.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID duy nhất" },
        "reactionName": { "type": "string", "description": "Tên phản ứng" },
        "description": { "type": "string", "description": "Mô tả chi tiết" },
        "commonDrugs": { "type": "array", "items": { "type": "string" }, "description": "Các thuốc thường gây ra phản ứng này" },
        "severityLevel": { "type": "string", "enum": ["Nhẹ", "Trung bình", "Nặng", "Nghiêm trọng"], "description": "Mức độ thường gặp" },
        "management": { "type": "string", "description": "Hướng dẫn xử trí" },
        "category": { "type": "string", "description": "Phân loại (Da liễu, Tiêu hóa...)" },
        "sortOrder": { "type": "number", "description": "Thứ tự sắp xếp" }
      },
      "required": ["id", "reactionName", "severityLevel", "category"]
    },
    "ConfigItem": {
      "title": "ConfigItem",
      "description": "Mục cấu hình hệ thống (Chức danh, Chức vụ, Chuyên môn).",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID duy nhất" },
        "name": { "type": "string", "description": "Tên mục" },
        "order": { "type": "number", "description": "Thứ tự hiển thị" }
      },
      "required": ["id", "name"]
    },
    "RolePermission": {
      "title": "RolePermission",
      "description": "Cấu hình quyền quản lý cho từng vai trò.",
      "type": "object",
      "properties": {
        "roleId": { "type": "string", "description": "ID vai trò (admin, operator, member)" },
        "allowedTabs": { "type": "array", "items": { "type": "string" }, "description": "Danh sách các tab được phép truy cập" }
      },
      "required": ["roleId", "allowedTabs"]
    },
    "TitlePermission": {
      "title": "TitlePermission",
      "description": "Cấu hình quyền sử dụng làm việc cho từng chức danh.",
      "type": "object",
      "properties": {
        "titleId": { "type": "string", "description": "ID chức danh (Bác sĩ, Dược sĩ...)" },
        "allowedTabs": { "type": "array", "items": { "type": "string" }, "description": "Danh sách các tab được phép truy cập" }
      },
      "required": ["titleId", "allowedTabs"]
    },
    "DrugGroup": {
      "title": "DrugGroup",
      "description": "Nhóm thuốc phân cấp (3 cấp).",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID duy nhất" },
        "name": { "type": "string", "description": "Tên nhóm thuốc" },
        "parentId": { "type": "string", "description": "ID nhóm cha (null nếu là cấp 1)" },
        "level": { "type": "number", "description": "Cấp độ (0, 1, 2)" },
        "order": { "type": "number", "description": "Thứ tự hiển thị" },
        "bannerUrl": { "type": "string", "description": "URL ảnh bìa nhóm thuốc" }
      },
      "required": ["id", "name", "level", "order"]
    },
    "ManualInteraction": {
      "title": "ManualInteraction",
      "description": "Tương tác thuốc được nhập thủ công.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Thuốc - Thuốc", "Thuốc - ICD-10", "Thuốc - Đối tượng", "Tương tác phức tạp"] },
        "sourceIds": { "type": "array", "items": { "type": "string" } },
        "sourceNames": { "type": "array", "items": { "type": "string" } },
        "targetName": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] },
        "description": { "type": "string" },
        "recommendation": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" },
        "updatedByName": { "type": "string" }
      },
      "required": ["id", "type", "sourceIds", "sourceNames", "severity", "description", "recommendation"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Thông tin hành chính và nhập viện của bệnh nhân.",
      "type": "object",
      "properties": {
        "MA_LK": { "type": "string" },
        "MA_BN": { "type": "string" },
