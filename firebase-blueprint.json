        "appDescription": { "type": "string", "description": "Mô tả ứng dụng ở trang đăng nhập" },
        "defaultTheme": { "type": "string", "enum": ["light", "dark"], "description": "Giao diện mặc định cho người dùng mới" },
        "loginLogoUrl": { "type": "string" },
        "loginBgUrl": { "type": "string" },
        "loginBgBlur": { "type": "number" },
        "loginBgOpacity": { "type": "number" },
        "loginPrimaryColor": { "type": "string" },
        "loginCardGlassMode": { "type": "boolean" },
        "termsOfUse": { "type": "string" },
        "termsUpdateDate": { "type": "string" },
        "showWelcomeSlider": { "type": "boolean" }
      }
    },
    "SocialPost": {
